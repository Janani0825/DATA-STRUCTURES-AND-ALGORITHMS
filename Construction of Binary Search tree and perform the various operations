BST::BST()
{
   root = NULL;
}
BST::~BST()
{
   root = NULL;
}
int BST::isEmpty()
{
   if(root == NULL)
      return 1;
   else
      return 0;
}
TreeNode *BST::insert(TreeNode *newNode)
{
   if(root == NULL)
      root = newNode;
   else
   {
      TreeNode *parent = NULL;
      TreeNode *temp = root;
      while(temp != NULL)
      {
         parent = temp;
         if(newNode -> num > temp -> num)
            temp = temp -> right;
         else if(newNode -> num < temp -> num)
            temp = temp -> left;
         else
            return NULL;
      }
      if(parent -> num < newNode -> num)
         parent -> right = newNode;
      else if(parent -> num > newNode -> num)
         parent -> left = newNode;
      else
         return NULL;
   }
   return root;
}
int BST::deletion(int elt)
{
   TreeNode *parent = NULL;
   TreeNode *temp = root;
   while(temp != NULL)
   {
      if(temp -> num == elt)
      {
         if(temp -> left == NULL && temp -> right == NULL)
         {
            if(temp == root)
               root = NULL;
            else
            {
               if(parent -> left == temp)
                  parent -> left = NULL;
               else
                  parent -> right = NULL;
            }
            delete temp;
            temp = NULL;
            return 1;
         }
         else if(temp -> left != NULL && temp -> right != NULL)
         {
            TreeNode *temp1 = temp -> right;
            while(temp1 -> left != NULL)
            {
               parent = temp1;
               temp1 = temp1 -> left;
            }
            temp -> num = temp1 -> num;
            if(temp1 -> right != NULL)
               parent -> left = temp1 -> right;
            else
               parent -> left = NULL;
            delete temp1;
            temp1 = NULL;
            return 1;
         }
         else
         {
            if(temp == root)
            {
               if(temp -> left != NULL && temp -> right == NULL)
                  root = temp -> left;
               else
                  root = temp ->right;
               delete temp;
               temp = NULL;
               return 1;
            }
            else
            {
               if(parent -> right == temp)
               {
                  if(temp -> right != NULL && temp -> left == NULL)
                     parent -> right = temp -> left;
                  else
                     parent -> right = temp -> right;
               }
               else
               {
                  if(temp -> left != NULL && temp -> right == NULL)
                     parent -> left = temp -> right;
                  else
                     parent -> left = temp -> left;
               }
            }
            delete temp;
            temp = NULL;
            return 1;
         }
      }
      else if(temp -> num > elt)
      {
         parent = temp;
         temp = temp -> left;
      }
      else
      {
         parent = temp;
         temp = temp -> right;
      }
   }
   return 0;
}
void BST::inorder(TreeNode *temp)
{
   if(temp != NULL)
   {
      inorder(temp -> left);
      temp -> displayDetails();
      inorder(temp -> right);
   }
}
void BST::preorder(TreeNode *temp)
{
   if(temp != NULL)
   {
      temp -> displayDetails();
      preorder(temp -> left);
      preorder(temp -> right);
   }
}
void BST::postorder(TreeNode *temp)
{
   if(temp != NULL)
   {
      postorder(temp -> left);
      postorder(temp -> right);
      temp -> displayDetails();
   }
}
TreeNode *BST::getRoot()
{
   return root;
}
TreeNode *BST::search(int key)
{
   TreeNode *temp = root;
   while(temp != NULL)
   {
      if(temp -> num == key)
      {
         return temp;
      }
      else if(key < temp -> num)
      {
         temp = temp -> left;
      }
      else
      {
         temp = temp -> right;
      }
   }
   return NULL;
}
TreeNode *BST::findMin(TreeNode *temp)
{
   if(temp -> left != NULL)
      findMin(temp -> left);
   else
      temp -> displayDetails();
}
TreeNode *BST::findMax(TreeNode *temp)
{
   if(temp -> right != NULL)
      findMax(temp -> right);
   else
      temp -> displayDetails();
}
