class TreeNode
{
   private:
      int num;
      char name[50];
      float price;
      TreeNode *left;
      TreeNode *right;
   public:
      friend class BST;
      TreeNode();
      void getDetails();
      void displayDetails();
};
class BST
{
   private:
      TreeNode *root;
   public:
      BST();
      ~BST();
      TreeNode *getRoot();
      void inorder(TreeNode *);
      int isEmpty();
      TreeNode *insert(TreeNode *);
      int deletion(int);
      void preorder(TreeNode *);
      void postorder(TreeNode *);
      TreeNode *search(int);
      TreeNode *findMin(TreeNode *);
      TreeNode *findMax(TreeNode *);
};
