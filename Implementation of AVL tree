AVLTreeNode *AVLTree::LLRotate(AVLTreeNode *k1)
{
   AVLTreeNode *k2 = k1 -> left;
   AVLTreeNode *temp = k2 -> right;
   k2 -> right = k1;
   k1 -> left = temp;
   k1 -> height = max(getHeight(k1 -> left),getHeight(k2 -> right))+1;
   k2 -> height = max(getHeight(k2 -> left),getHeight(k2 -> right))+1;
   return k2;
}
AVLTreeNode *AVLTree::RRRotate(AVLTreeNode *k1)
{
   AVLTreeNode *k2 = k1 -> right;
   AVLTreeNode *temp = k2 -> left;
   k2 -> left = k1;
   k1 -> right = temp;
   k1 -> height = max(getHeight(k1 -> left),getHeight(k2 -> right))+1;
   k2 -> height = max(getHeight(k2 -> left),getHeight(k2 -> right))+1;
   return k2;
}
AVLTreeNode *AVLTree::LRRotate(AVLTreeNode *k1)
{
   k1 -> left = RRRotate(k1 -> left);
   return LLRotate(k1);
}
AVLTreeNode *AVLTree::RLRotate(AVLTreeNode *k1)
{
   k1 -> right = LLRotate(k1 -> right);
   return RRRotate(k1);
}
int AVLTree:: getHeight(AVLTreeNode *myNode)
{
   if(myNode == NULL)
      return -1;
   return myNode -> height;
}
int AVLTree::BF(AVLTreeNode *myNode)
{
   if(myNode == NULL)
      return -1;
   return getHeight(myNode -> left) - getHeight(myNode -> right);
}
void AVLTree::insertion(AVLTreeNode *newNode)
{
   root = insert(root,newNode);
}
AVLTreeNode *AVLTree::insert(AVLTreeNode *temp, AVLTreeNode *newNode)
{

   if(root == NULL)
   {
      root = newNode;
      return root;
   }
   else if(temp -> num > newNode -> num)
   {
      if(temp -> left == NULL)
         temp -> left = newNode;
      else
         temp -> left = insert(temp -> left,newNode);
   }
   else if (temp -> num < newNode -> num)
   {
      if(temp -> right == NULL)
         temp -> right = newNode;
      else
       temp -> right = insert(temp -> right,newNode);
   }
   temp -> height = max(getHeight(temp -> left),getHeight(temp -> right))+1;
   int balance=BF(temp);
   if(balance > 1){
      if(newNode -> num < temp -> left -> num)
         return LLRotate(temp);
      else
         return LRRotate(temp);
   }
   if(balance < -1){
      if(newNode -> num > temp -> right -> num)
         return RRRotate(temp);
      else
         return RLRotate(temp);
   }
   return temp;
}

void AVLTree::inorder(AVLTreeNode *temp)
{
   if(temp != NULL)
   {
      inorder(temp -> left);
      temp -> displayDetails();
      inorder(temp -> right);
   }
}
void AVLTree::preorder(AVLTreeNode *temp)
{
   if(temp != NULL)
   {
      temp -> displayDetails();
      preorder(temp -> left);
      preorder(temp -> right);
   }
}
void AVLTree::postorder(AVLTreeNode *temp)
{
   if(temp != NULL)
   {
      postorder(temp -> left);
      postorder(temp -> right);
      temp -> displayDetails();
   }
}
AVLTreeNode *AVLTree::getRoot()
{
   return root;
}
AVLTreeNode *AVLTree::search(int key)
{
   AVLTreeNode *temp = root;
   while(temp != NULL)
   {
      if(temp -> num == key)
      {
         return temp;
      }
      else if(key < temp -> num)
      {
         temp = temp -> left;
      }
      else
      {
         temp = temp -> right;
      }
   }
   return NULL;
}
AVLTreeNode *AVLTree::findMin(AVLTreeNode *temp)
{
   if(temp -> left != NULL)
      findMin(temp -> left);
   else
      temp -> displayDetails();
}
AVLTreeNode *AVLTree::findMax(AVLTreeNode *temp)
{
   if(temp -> right != NULL)
      findMax(temp -> right);
   else
      temp -> displayDetails();
}
