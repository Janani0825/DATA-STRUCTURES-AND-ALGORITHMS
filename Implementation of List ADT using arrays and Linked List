int L_List::insertAtFirst(Node* newNode)
{
    if (isEmpty())
    {
        first = newNode;
    }
    else
    {
        newNode->next = first;
        first = newNode;
    }
    return 1;
}

int L_List::insertAtLast(Node* newNode)
{
    if (isEmpty())
    {
        first = newNode;
    }
    else
    {
        Node* temp = first;
        while (temp->next != NULL)
        {
            temp = temp->next;
        }
        temp->next = newNode;
    }
    return 1;
}

int L_List::deleteByProductId(int id)
{
    if (isEmpty())
       return -1;
    Node* prev = NULL;
    Node* temp = first;
    while (temp != NULL && temp->getProductId() != id)
    {
        prev = temp;
        temp = temp->next;
    }
    if (temp == NULL)
       return -2;

    if (prev == NULL)
    {
        first = first->next;
    }
    else
    {
        prev->next = temp->next;
    }
    delete temp;
    return 1;
}

int L_List::deleteByPosition(int pos)
{
    if (isEmpty())
       return -1;
    if (pos < 1)
       return -2;
    Node* prev = NULL;
    Node* temp = first;
    int currentPos = 1;
    while (temp != NULL && currentPos < pos)
    {
        prev = temp;
        temp = temp->next;
        currentPos++;
    }
    if (temp == NULL)
       return -2;
    if (prev == NULL)
    {
        first = first->next;
    }
    else
    {
        prev->next = temp->next;
    }
    delete temp;
    return 1;
}

int L_List::updateByPosition(int pos, int newId, string newName, float newPrice)
{
    if (isEmpty())
       return -1;
    Node* temp = first;
    int currentPos = 1;
    while (temp != NULL && currentPos < pos)
    {
        temp = temp->next;
        currentPos++;
    }
    if (temp == NULL)
       return -2;
    temp->productId = newId;
    temp->name = newName;
    temp->price = newPrice;
    return 1;
}

int L_List::updateByProductId(int oldId, int newId, string newName, float newPrice)
{
    if (isEmpty())
       return -1;
    Node* temp = first;
    while (temp != NULL && temp->getProductId() != oldId)
    {
        temp = temp->next;
    }
    if (temp == NULL)
       return -2;
    temp->productId = newId;
    temp->name = newName;
    temp->price = newPrice;
    return 1;
}

int L_List::searchByProductId(int id)
{
    if (isEmpty())
       return -1;
    Node* temp = first;
    int position = 1;
    while (temp != NULL)
    {
        if (temp->getProductId() == id)
        {
            return position;
        }
        temp = temp->next;
        position++;
    }
    return -2;
}

int L_List::searchByPosition(int pos)
{
    if (isEmpty())
       return -1;
    Node* temp = first;
    int currentPos = 1;
    while (temp != NULL && currentPos < pos)
    {
        temp = temp->next;
        currentPos++;
    }
    if (temp == NULL)
       return -2;
    temp->displayDetails();
    cout << endl;
    return 1;
}

int L_List::deleteAtFirst()
{
    if (isEmpty())
       return 0;
    Node* temp = first;
    first = first->next;
    delete temp;
    return 1;
}

int L_List::deleteAtLast()
{
    if (isEmpty())
       return 0;
    if (first->next == NULL) {
        delete first;
        first = NULL;
    }
    else
    {
        Node* prev = NULL;
        Node* temp = first;
        while (temp->next != NULL)
        {
            prev = temp;
            temp = temp->next;
        }
        prev->next = NULL;
        delete temp;
    }
    return 1;
}

int L_List::displayList()
{
    if (isEmpty())
    {
        cout << "List is empty!" << endl;
        return 0;
    }
    Node* temp = first;
    int count = 1;
    while (temp != NULL)
    {
        cout << count << ". ";
        temp->displayDetails();
        cout << endl;
        temp = temp->next;
        count++;
    }
    return 1;
}

int L_List::makeListEmpty()
{
    Node* temp;
    while (first != NULL)
    {
        temp = first;
        first = first->next;
        delete temp;
    }
    return 1;
}

int L_List::insertByPos(Node* newNode, int pos)
{
    if (isEmpty() && pos == 1)
    {
        first = newNode;
        return 1;
    }
    if (pos < 1)
       return -2;
    Node* temp = first;
    int currentPos = 1;
    while (temp != NULL && currentPos < pos - 1)
    {
        temp = temp->next;
        currentPos++;
    }
    if (temp == NULL)
       return -2;
    newNode->next = temp->next;
    temp->next = newNode;
    return 1;
}

int L_List::insertAfterGivenElement(Node* newNode, int afterId)
{
    if (isEmpty())
       return -1;
    Node* temp = first;
    while (temp != NULL && temp->getProductId() != afterId)
    {
        temp = temp->next;
    }
    if (temp == NULL)
       return -2;
    newNode->next = temp->next;
    temp->next = newNode;
    return 1;
}

int L_List::insertBeforeGivenElement(Node* newNode, int beforeId)
{
    if (isEmpty())
       return -1;
    Node* prev = NULL;
    Node* temp = first;
    while (temp != NULL && temp->getProductId() != beforeId)
    {
        prev = temp;
        temp = temp->next;
    }
    if (temp == NULL)
       return -2;
    if (prev == NULL)
    {
        newNode->next = first;
        first = newNode;
    }
    else
    {
        newNode->next = temp;
        prev->next = newNode;
    }
    return 1;
}

