A_list::A_list() {
    size = 0;
    capacity = 20;
    arr = new Node[capacity];
}
A_list::~A_list() {
    delete[] arr;
}
int A_list::isFull() {
    return size == capacity;
}
int A_list::isEmpty() {
    return size == 0;
}
int A_list::insertAtFirst(Node element) {
    if (!isFull()) {
        if (isEmpty()) {
            arr[size++] = element;
        } else {
            for (int i = size; i > 0; i--)
                arr[i] = arr[i-1];
            arr[0] = element;
            size++;
        }
        return 1;
    }
    return 0;
}
int A_list::insertAtLast(Node element) {
    if (!isFull()) {
        arr[size++] = element;
        return 1;
    }
    return 0;
}
int A_list::insertByPosition(Node element, int pos) {
    if (isFull()) return 0;
    if (pos < 1 || pos > size+1) return -1;

    if (pos == 1) return insertAtFirst(element);
    if (pos == size+1) return insertAtLast(element);

    for (int i = size; i >= pos; i--)
        arr[i] = arr[i-1];
    arr[pos-1] = element;
    size++;
    return 1;
}
int A_list::deleteFromFront() {
    if (isEmpty()) return 0;
    for (int i = 0; i < size-1; i++)
        arr[i] = arr[i+1];
    size--;
    return 1;
}
int A_list::deleteFromLast() {
    if (isEmpty()) return 0;
    size--;
    return 1;
}
int A_list::deleteByPosition(int pos) {
    if (isEmpty()) return 0;
    if (pos < 1 || pos > size) return -1;

    if (pos == 1) return deleteFromFront();
    if (pos == size) return deleteFromLast();

    for (int i = pos-1; i < size-1; i++)
        arr[i] = arr[i+1];
    size--;
    return 1;
}
int A_list::deleteByValue(int id) {
    if (isEmpty()) return 0;

    for (int i = 0; i < size; i++) {
        if (arr[i].pid == id) {
            for (int j = i; j < size-1; j++)
                arr[j] = arr[j+1];
            size--;
            return 1;
        }
    }
    return -1;
}
Node A_list::getElementAtPosition(int pos) {
    if (pos < 1 || pos > size) {
        Node emptyNode;
        return emptyNode;
    }
    return arr[pos-1];
}
int A_list::searchByElement(int id) {
    for (int i = 0; i < size; i++) {
        if (arr[i].pid == id) {
            return i+1; // Return position (1-based)
        }
    }
    return -1; // Not found
}
int A_list::updateElement(int id) {
    for (int i = 0; i < size; i++) {
        if (arr[i].pid == id) {
            arr[i].updateDetails();
            return 1;
        }
    }
    return 0;
}
void A_list::makeListEmpty() {
    size = 0;
}
void A_list::displayArray() {
    if (isEmpty()) {
        cout << "List is empty!" << endl;
        return;
    }

    cout << "\nPRODUCT DETAILS " << size <<"\n";
