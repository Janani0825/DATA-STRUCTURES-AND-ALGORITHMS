#include <string>
using namespace std;

class Node {
private:
    int id;
    string name;
    float price;
public:
    Node();
    friend class LHash;
    void getDetails();
    void displayDetails();
};

class LHash {
private:
    Node* table;
    int size;
public:
    LHash(int c);
    int hashFunc(int key);
    int insertItem(Node key);
    int deleteItem(int key);
    bool searchItem(int key);
    void displayTable();
};
#include <iostream>
#include "head.h"
using namespace std;

Node::Node() {
    id = -1;  // -1 means empty slot
    name = "";
    price = 0.0;
}

LHash::LHash(int c) {
    size = c;
    table = new Node[size];
    for (int i = 0; i < size; i++) {
        table[i].id = -1;
        table[i].name = "";
        table[i].price = 0.0;
    }
}

int LHash::hashFunc(int key) {
    return key % size;
}

int LHash::insertItem(Node key) {
    int index = hashFunc(key.id);
    int start = index;
    while (table[index].id != -1) {
        index = (index + 1) % size;
        if (index == start) {
            cout << "Hash table is full. Cannot insert." << endl;
            return 0;
        }
    }
    table[index] = key;
    cout << "Inserted at index " << index << endl;
    return 1;
}

bool LHash::searchItem(int key) {
    int index = hashFunc(key);
    int start = index;
    while (table[index].id != -1) {
        if (table[index].id == key) {
            cout << key << " found at index: " << index << endl;
            return true;
        }
        index = (index + 1) % size;
        if (index == start)
            return false;
    }
    cout << key << " not found in the hash table." << endl;
    return false;
}

int LHash::deleteItem(int key) {
    int index = hashFunc(key);
    int start = index;
    while (table[index].id != -1) {
        if (table[index].id == key) {
            table[index].id = -1;
            table[index].name = "";
            table[index].price = 0.0;
            cout << key << " deleted from index " << index << endl;
            return 1;
        }
        index = (index + 1) % size;
        if (index == start)
            return 0;
    }
    cout << key << " not found to delete." << endl;
    return 0;
}

void LHash::displayTable() {
    cout << "Hash Table [Linear Probing]:" << endl;
    for (int i = 0; i < size; i++) {
        if (table[i].id == -1)
            cout << i << ": [empty node]" << endl;
        else {
            cout << i << ": ";
            table[i].displayDetails();
            cout << endl;
        }
    }
}

void Node::getDetails() {
    cout << "Enter id: ";
    cin >> id;
    cout << "Enter name: ";
    cin >> name;
    cout << "Enter price: ";
    cin >> price;
}

void Node::displayDetails() {
    cout << "id: " << id << ", name: " << name << ", price: " << price;
}
