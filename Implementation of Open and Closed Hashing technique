#include <iostream>
#include <string>
using namespace std;

struct Node {
    int id;
    string name;
    float mark;
    Node* next;
};

class Hash {
private:
    int size;
    Node** table;

public:
    Hash(int tablesize);
    int hashFunction(int id);
    void insertKey(int id, const string& name, float mark);
    void searchHash(int id);
    void deleteKey(int id);
    void displayTable();
    ~Hash();
};
#include "head.h"

Hash::Hash(int tablesize) {
    size = tablesize;
    table = new Node*[size];
    for (int i = 0; i < size; i++)
        table[i] = NULL;
}

int Hash::hashFunction(int id) {
    return id % size;
}

void Hash::insertKey(int id, const string& name, float mark) {
    int index = hashFunction(id);
    Node* newNode = new Node;
    newNode->id = id;
    newNode->name = name;
    newNode->mark = mark;
    newNode->next = NULL;

    if (table[index] == NULL) {
        // Empty list, insert as first node
        table[index] = newNode;
    } else {
        // Insert at end to maintain insertion order
        Node* current = table[index];
        while (current->next != NULL)
            current = current->next;
        current->next = newNode;
    }
    cout << "Inserted " << id << " at index " << index << endl;
}

void Hash::searchHash(int id) {
    int index = hashFunction(id);
    Node* current = table[index];
    while (current != NULL) {
        if (current->id == id) {
            cout << "Found at index " << index << ": ";
            cout << "ID: " << current->id << ", Name: " << current->name << ", Mark: " << current->mark << endl;
            return;
        }
        current = current->next;
    }
    cout << "Not Found: " << id << endl;
}

void Hash::deleteKey(int id) {
    int index = hashFunction(id);
    Node* current = table[index];
    Node* prev = NULL;

    while (current != NULL) {
        if (current->id == id) {
            if (prev == NULL)
                table[index] = current->next;
            else
                prev->next = current->next;

            delete current;
            cout << "Deleted " << id << " from index " << index << endl;
            return;
        }
        prev = current;
        current = current->next;
    }
    cout << "Key not found: " << id << endl;
}

void Hash::displayTable() {
    cout << "\n--- Hash Table ---\n";
    for (int i = 0; i < size; i++) {
        cout << "Index " << i << ": ";
        Node* current = table[i];
        while (current != NULL) {
            cout << "[" << current->id << ", " << current->name << ", " << current->mark << "] -> ";
            current = current->next;
        }
        cout << "NULL" << endl;
    }
}

Hash::~Hash() {
    for (int i = 0; i < size; i++) {
        Node* current = table[i];
        while (current != NULL) {
            Node* temp = current;
            current = current->next;
            delete temp;
        }
    }
    delete[] table;
}
int main() {
    int size;
    cout << "Enter table size: ";
    cin >> size;

    Hash h(size);
    int choice, id;
    string name;
    float mark;

    do {
        cout << "\n--- Hash Table Menu ---\n";
        cout << "1. Insert\n";
        cout << "2. Search\n";
        cout << "3. Delete\n";
        cout << "4. Display\n";
        cout << "5. Exit\n";
        cout << "Enter choice: ";
        cin >> choice;

        switch (choice) {
            case 1:
                cout << "Enter ID to insert: ";
                cin >> id;
                cin.ignore();  // clear newline for getline
                cout << "Enter Name: ";
                getline(cin, name);
                cout << "Enter Mark: ";
                cin >> mark;
                h.insertKey(id, name, mark);
                break;

            case 2:
                cout << "Enter ID to search: ";
                cin >> id;
                h.searchHash(id);
                break;

            case 3:
                cout << "Enter ID to delete: ";
                cin >> id;
                h.deleteKey(id);
                break;

            case 4:
                h.displayTable();
                break;

            case 5:
                cout << "Exiting...\n";
                break;

            default:
                cout << "Invalid choice!\n";
        }
    } while (choice != 5);

    return 0;
}
