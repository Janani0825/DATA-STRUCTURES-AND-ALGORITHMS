    Node();
    void getDetails();
    void displayDetails();
};

class QuadHash {
private:
    Node* table;
    int size;
public:
    QuadHash(int c);
    ~QuadHash();
    int hashFunction(int key);
    void insertItem(Node key);
    void searchItem(int key);
    void deleteItem(int key);
    void displayTable();
};
#include <iostream>
#include "head.h"
using namespace std;

// Node class implementation
Node::Node() {
    id = -1;
    name = "";
    price = 0.0;
}

void Node::getDetails() {
    cout << "Enter ID: ";
    cin >> id;
    cout << "Enter name: ";
    cin.ignore();  // Clear newline for getline
    getline(cin, name);
    cout << "Enter price: ";
    cin >> price;
}

void Node::displayDetails() {
    cout << "ID: " << id << ", Name " << name << ", Price: " << price << endl;
}

// QuadHash class implementation
QuadHash::QuadHash(int c) {
    size = c;
    table = new Node[size];
    for (int i = 0; i < size; i++) {   // <-- Corrected constructor loop
        table[i].id = -1;  // Mark as empty
    }
}

QuadHash::~QuadHash() {
    delete[] table;
}

int QuadHash::hashFunction(int key) {
    return key % size;
}

void QuadHash::insertItem(Node key) {
    int index = hashFunction(key.id);
    int i = 0;
    while (i < size) {
        int newIndex = (index + i * i) % size;
        if (table[newIndex].id == -1) {  // Empty slot found
            table[newIndex] = key;
            cout << "Inserted at index " << newIndex << endl;
            return;
        }
        i++;
    }
    cout << "Hash table is full." << endl;
}

void QuadHash::searchItem(int key) {
    int index = hashFunction(key);
    int i = 0;
    while (i < size) {
        int newIndex = (index + i * i) % size;
        if (table[newIndex].id == key) {
            cout << "Node found at index " << newIndex << ": ";
            table[newIndex].displayDetails();
            return;
        } else if (table[newIndex].id == -1) {
            break;  // Empty slot means not found
        }
        i++;
    }
    cout << "Node not found." << endl;
}

void QuadHash::deleteItem(int key) {
    int index = hashFunction(key);
    int i = 0;
    while (i < size) {
        int newIndex = (index + i * i) % size;
        if (table[newIndex].id == key) {
            table[newIndex].id = -1;  // Mark as deleted (empty)
            cout << "Deleted node at index " << newIndex << endl;
            return;
        } else if (table[newIndex].id == -1) {
            break;  // Empty slot means not found
        }
        i++;
    }
    cout << "Node not found." << endl;
}

void QuadHash::displayTable() {
    cout << "Hash Table with Quadratic Probing:" << endl;
    for (int i = 0; i < size; i++) {
        cout << "Index " << i << ": ";
        if (table[i].id == -1) {
            cout << "Empty" << endl;
        } else {
            table[i].displayDetails();
        }
    }
}
