}

int main() {
   Heap p;
   Node n;
   int choice;

   do {
      displayMenu();
      cout << "Enter your choice: ";
      cin >> choice;

      switch(choice) {
         case 1:
            n.getDetails();
            p.insert(n);
            p.display();
            break;
         case 2:
            n = p.deletemin();
            cout << "\nDeleted Minimum Priority :\n";
            n.putDetails();
            break;
         case 3:
            p.display();
            break;
         case 4:
            cout << "Exiting...\n";
            break;
         default:
            cout << "Invalid choice. Try again.\n";
      }
   } while(choice != 4);

   return 0;
}

