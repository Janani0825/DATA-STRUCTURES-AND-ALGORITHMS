#include<iostream>
using namespace std;

class Node {
   private:
      int id;
      char name[50];
      float price;
   public:
      friend class Heap;
      Node();
      void getDetails();
      void putDetails();
};

class Heap {
   public:
      Heap();
      ~Heap();
      int insert(Node x);
      Node deletemin();
      int isFull();
      int isEmpty();
      void display();
   private:
      Node *arr;
      int capacity;
      int size;
};
