#include <iostream>
#include <string.h>
using namespace std;
class Node
{
   private:
      int num;
      char name[50];
      float price;
   public:
      friend class C_Queue;
      Node();
      void getDetails();
      void displayDetails();
};
class C_Queue
{
   private:
      Node *arr;
      int capacity;
      int front;
      int rear;
   public:
      C_Queue();
      ~C_Queue();
      int isFull();
      int isEmpty();
      int enqueue(Node);
      int displayQueue();
      int dequeue();
      int peek();
      int size();
      int makeStackEmpty();
};
#include "head.h"
Node::Node()
{
   num = 0;
   strcpy(name," ");
   price = 0.0;
}
void Node::getDetails()
{
   cout << "Enter product number:";
   cin >> num;
   cout << "Enter product name:";
   cin >> name;
   cout << "Enter product price:";
   cin >> price;
}
void Node::displayDetails()
{
   cout << "Product number:" << num << "\n";
   cout << "Product name:" << name << "\n";
   cout << "Product price:" << price << "\n";
}
C_Queue::C_Queue()
{
   capacity = 50;
   front = -1;
   rear = -1;
   arr = new Node[capacity];
}
C_Queue::~C_Queue()
{
   capacity = 0;
   front =-1;
   rear = -1;
   delete[] arr;
   arr = NULL;
}
int C_Queue::isFull()
{
   if(((rear + 1) % capacity) == front)
      return 1;
   else
      return 0;
}
int C_Queue::isEmpty()
{
   if(front == -1 && rear == -1)
      return 1;
   else
      return 0;
}
int C_Queue::enqueue(Node newNode)
{
   if(!isFull())
   {
      if(isEmpty())
      {
         front = 0;
         rear = 0;
         arr[rear] = newNode;
      }
      else
      {
         rear = (rear + 1) % capacity;
         arr[rear] = newNode;
      }
      return 1;
   }
   else
      return 0;
}
int C_Queue::displayQueue()
{
   int i;
   if(!isEmpty())
   {
      for(i=front;i!=rear;i=(i+1)%capacity)
      {
         cout << "Product number:" << arr[i].num << "\n";
         cout << "Product name:" << arr[i].name << "\n";
         cout << "Product priceRs:" << arr[i].price << "\n";
         cout << "\n";
      }
      cout << "product number:" << arr[i].num << "\n";
      cout << "Product name:" << arr[i].name << "\n";
      cout << "Product price:Rs" << arr[i].price << "\n";
   }
}
int C_Queue::dequeue()
{
   if(!isEmpty())
   {
      if(front == rear)
      {
         front = -1;
         rear = -1;
      }
      else
         front = (front+1)%capacity;
      return 1;
   }
   else
      return 0;
}
int C_Queue::peek()
{
   if(!isEmpty())
   {
      arr[front].displayDetails();
   }
   else
      return 0;
}
int C_Queue::size()
{
   if(!isEmpty())
   {
      int count = 0;
      for(int i=front;i!=rear;i=(i+1)%capacity)
      {
         count++;
      }
      count++;
      return count;
   }
   else
      return 0;
}
int C_Queue::makeStackEmpty()
{
   while(!isEmpty())
   {
      dequeue();
   }
   return 1;
}
