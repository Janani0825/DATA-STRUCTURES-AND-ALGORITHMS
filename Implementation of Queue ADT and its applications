#include <iostream>
#include <string.h>
using namespace std;
class Node
{
   private:
      int num;
      char name[50];
      float price;
      Node *next;
   public:
      friend class L_Queue;
      Node();
      void getDetails();
      void displayDetails();
};
class L_Queue
{
   private:
      Node *front;
   public:
      L_Queue();
      ~L_Queue();
      int isEmpty();
      int enqueue(Node *);
      int displayQueue();
      int dequeue();
      int peek();
      int size();
      int makeQueueEmpty();
};
#include "head.h"
Node::Node()
{
   num = 0;
   strcpy(name," ");
   price = 0.0;
   next = NULL;
}
void Node::getDetails()
{
   cout << "Enter product number:";
   cin >> num;
   cout << "Enter product name:";
   cin >> name;
   cout << "Enter product price:";
   cin >> price;
}
void Node::displayDetails()
{
   cout << "Product number:" << num << "\n";
   cout << "Product name:" << name << "\n";
   cout << "Product price:" << price << "\n";
   cout << "\n";
}
L_Queue::L_Queue()
{
   front = NULL;
}
L_Queue::~L_Queue()
{
   front = NULL;
}
int L_Queue::isEmpty()
{
   if(front == NULL)
      return 1;
   else
      return 0;
}
int L_Queue::enqueue(Node *newNode)
{
   if(isEmpty())
   {
      front = newNode;
   }
   else
   {
      Node *temp = front;
      while(temp -> next != NULL)
      {
         temp = temp -> next;
      }
      temp -> next = newNode;
   }
   return 1;
}
int L_Queue::displayQueue()
{
   if(!isEmpty())
   {
      Node *temp = front;
      while(temp -> next != NULL)
      {
         cout << "Product number:" << temp -> num << "\n";
         cout << "Product name:" << temp -> name << "\n";
         cout << "Product price:Rs" << temp -> price << "\n";
         cout << "\n";
         temp = temp -> next;
      }
      cout << "Product number:" << temp -> num << "\n";
      cout << "Product name:" << temp -> name << "\n";
      cout << "Product price:Rs" << temp -> price << "\n";
   }
   else
      cout << "After deletion queue become empty.\n";
}
int L_Queue::dequeue()
{
   if(isEmpty())
      return 0;
   else
   {
      Node *temp = front;
      front = front -> next;
      delete temp;
      temp = NULL;
   }
   return 1;
}
int L_Queue::peek()
{
   if(!isEmpty())
   {
      cout << "Product number:" << front -> num << "\n";
      cout << "Product name:" << front -> name << "\n";
      cout << "Product price:" << front -> price << "\n";
      return 1;
   }
   else
      return 0;
}
int L_Queue::size()
{
   Node *temp = front;
   int count = 0;
   while(temp -> next != NULL)
   {
      count++;
      temp = temp -> next;
   }
   count++;
   return count;
}
int L_Queue::makeQueueEmpty()
{
   while(!isEmpty())
   {
      dequeue();
   }
   return 1;
}
int main()
{
   int ret,ch;
   Node *n;
   L_Queue l;
   do
   {
      cout << "*************************************\n";
