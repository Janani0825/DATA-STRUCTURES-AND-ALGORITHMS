#include <iostream>
#include <string.h>
using namespace std;
class Node
{
   private:
      int num;
      char name[20];
      float price;
   public:
      friend class A_Stack;
      Node();
      void getDetails();
      void displayDetails();
};
class A_Stack
{
   private:
      Node *stackArr;
      int capacity;
      int top;
   public:
      A_Stack();
      ~A_Stack();
      int push(Node);
      int isFull();
      int isEmpty();
      int displayStack();
      int pop();
      int peek();
      int size();
      int makeStackEmpty();
};
#include "head.h"
Node::Node()
{
   num = 0;
   strcpy(name," ");
   price = 0.0;
}
void Node::getDetails()
{
   cout << "Enter product num:";
   cin >> num;
   cout << "Enter product name:";
   cin >> name;
   cout << "Enter product price:";
   cin >> price;
}
void Node::displayDetails()
{
   cout << "Product number:" << num << "\n";
   cout << "Product name:" << name << "\n";
   cout << "Product price:Rs" << price << "\n";
}
A_Stack::A_Stack()
{
   capacity = 10;
   top = -1;
   stackArr = new Node[capacity];
}
A_Stack::~A_Stack()
{
   capacity = 0;
   top = -1;
   delete[] stackArr;
   stackArr = NULL;
}
int A_Stack::isFull()
{
   if(top+1 == capacity)
      return 1;
   else
      return 0;
}
int A_Stack::isEmpty()
{
   if(top == -1)
      return 1;
   else
      return 0;
}
int A_Stack::push(Node elt)
{
   if(!isFull())
   {
      top++;
      stackArr[top] = elt;
      return 1;
   }
   else
      return 0;
}
int A_Stack::pop()
{
   if(!isEmpty())
   {
      top--;
      return 1;
   }
   else
      return 0;
}
int A_Stack::displayStack()
{
   if(!isEmpty())
   {
      for(int i=0;i<=top;i++)
      {
         cout << "Product number:" << stackArr[i].num << "\n";
         cout << "Product name:" << stackArr[i].name << "\n";
         cout << "Product price:Rs" << stackArr[i].price << "\n";
         cout << "\n";
      }
      return 1;
   }
   else
      return 0;
}
int A_Stack::peek()
{
   if(!isEmpty())
      stackArr[top].displayDetails();
   else
      return 0;
}
int A_Stack::size()
{
   if(!isEmpty())
      return top+1;
   else
      return 0;
}
int A_Stack::makeStackEmpty()
{
   while(!isEmpty())
   {
      top--;
   }
   return 1;
}
int main()
{
   int ret,ch;
   Node n;
   A_Stack s;
   do {
      cout << "**************************************\n";
