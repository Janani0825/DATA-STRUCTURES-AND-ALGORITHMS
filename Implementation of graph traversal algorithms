#include <iostream>
#include <string>
using namespace std;
const int MAX_VERTICES = 10;
class Node {
private:
    string name;
    int id;
    float price;

public:
    void getDetails();
    void displayDetails() const;
};

class Queue {
private:
    int capacity;
    int data[MAX_VERTICES];
    int front, rear;

public:
    Queue(int cap);
    bool isEmpty() const;
    void enqueue(int val);
    int dequeue();
};

class Graph {
private:
    int vertices;
    Node nodeList[MAX_VERTICES];
    int adjMatrix[MAX_VERTICES][MAX_VERTICES];

public:
    Graph(int v);
    void addEdge(int src, int dest);
    void getDetails();
    void getVertices() const;
    void dfs(int start);
    void bfs(int start);
    void displayMatrix();
};
#include "head.h"
void Node::getDetails() {
    cout << "Enter name: ";
    cin >> name;
    cout << "Enter ID: ";
    cin >> id;
    cout << "Enter Price: ";
    cin >> price;
}

void Node::displayDetails() const {
    std::cout << "Name: " << name << ", ID: " << id << ", Price: " << price << std::endl;
}

Queue::Queue(int cap) : capacity(cap), front(0), rear(0) {}

bool Queue::isEmpty() const {
    return front == rear;
}

void Queue::enqueue(int val) {
    if (rear < capacity) {
        data[rear++] = val;
    }
}

int Queue::dequeue() {
    if (!isEmpty()) {
        return data[front++];
    }
    return -1;
}

Graph::Graph(int v) : vertices(v) {
    for (int i = 0; i < vertices; ++i)
        for (int j = 0; j < vertices; ++j)
            adjMatrix[i][j] = 0;
}

void Graph::addEdge(int src, int dest) {
    adjMatrix[src][dest] = 1;
    adjMatrix[dest][src] = 1;
}

void Graph::getDetails() {
    for (int i = 0; i < vertices; ++i) {
        cout << "Enter details for vertex " << i << ":\n";
        nodeList[i].getDetails();
    }
}

void Graph::getVertices() const {
    for (int i = 0; i < vertices; ++i) {
        cout << "Vertex " << i << ": ";
        nodeList[i].displayDetails();
    }
}

void Graph::dfs(int start) {
    bool visited[MAX_VERTICES] = {false};
    int stack[MAX_VERTICES];
    int top = -1;

    stack[++top] = start;

    cout << "DFS Traversal: ";
    while (top != -1) {
        int curr = stack[top--];
        if (!visited[curr]) {
            visited[curr] = true;
            cout << curr << " ";
            for (int i = vertices - 1; i >= 0; --i) {
                if (adjMatrix[curr][i] && !visited[i]) {
                    stack[++top] = i;
                }
            }
        }
    }
    std::cout << std::endl;
}

void Graph::bfs(int start) {
    bool visited[MAX_VERTICES] = {false};
    Queue q(vertices);
    q.enqueue(start);
    visited[start] = true;

    cout << "BFS Traversal: ";
    while (!q.isEmpty()) {
        int curr = q.dequeue();
        cout << curr << " ";
        for (int i = 0; i < vertices; ++i) {
            if (adjMatrix[curr][i] && !visited[i]) {
                q.enqueue(i);
                visited[i] = true;
            }
        }
    }
    cout << endl;
}
void Graph::displayMatrix(){
   for(int i =0;i< vertices ; i++){
      for(int j=0;j<vertices;j++){
         cout<<adjMatrix[i][j]<<"\t";
      }
      cout <<"\n";
   }
}
int main() {
    int choice, v, src, dest, start;

    std::cout << "Enter number of vertices (max " << MAX_VERTICES << "): ";
    std::cin >> v;
    if (v > MAX_VERTICES) {
        std::cout << "Too many vertices!\n";
        return 1;
    }

    Graph g(v);

    while (true) {
        std::cout << "\nMenu:\n";
        std::cout << "1. Insert Node to the graph\n";
        std::cout << "2. Display Node in the graph\n";
        std::cout << "3. Add Edge\n";
        std::cout << "4. DFS Traversal\n";
        std::cout << "5. BFS Traversal\n";
        std::cout << "6. DisplayMatrix\n";
        std::cout << "7. Exit\n";
        std::cout << "Enter your choice: ";
        std::cin >> choice;

        switch (choice) {
            case 1:
                g.getDetails();
                break;
            case 2:
                g.getVertices();
                break;
            case 3:
                cout << "Enter source and destination: ";
                cin >> src >> dest;
                g.addEdge(src, dest);
                break;
            case 4:
                std::cout << "Enter starting vertex for DFS: ";
                std::cin >> start;
                g.dfs(start);
                break;
            case 5:
                std::cout << "Enter starting vertex for BFS: ";
                std::cin >> start;
                g.bfs(start);
                break;
            case 6:
                g.displayMatrix();
                break;
            case 7:
                return 0;
            default:
                std::cout << "Invalid choice!\n";
        }
    }
}
